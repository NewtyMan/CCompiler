:name: c-testsuite - #00036
:is_system:
:input:
int
main()
{
	int x;

	x = 0;
	x += 2;
	x += 2;
	if (x != 4)
		return 1;
	x -= 1;
	if (x != 3)
		return 2;
	x *= 2;
	if (x != 6)
		return 3;

	return 0;
}
:input:
:output:
:output:
:testcase:

:testcase:
:name: c-testsuite - #00041
:is_system:
:input:
int
main() {
	int n;
	int t;
	int c;
	int p;

	c = 0;
	n = 2;
	while (n < 5000) {
		t = 2;
		p = 1;
		while (t*t <= n) {
			if (n % t == 0)
				p = 0;
			t++;
		}
		n++;
		if (p)
			c++;
	}
	if (c != 669)
		return 1;
	return 0;
}
:input:
:output:
:output:
:testcase:
