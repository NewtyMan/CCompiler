    int x = 0;
    int *y = &x;
    int **z = &y;

    return **z;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
  [FuncBody]
    [CompoundStmt]
      [Declarations]
        [Declarator, name=x, type=( int )]
          [Constant, type=NumberOct, value='0']
      [Declarations]
        [Declarator, name=y, type=( int* )]
          [Unary, operator=&]
            [Constant, type=Identifier, value='x']
      [Declarations]
        [Declarator, name=z, type=( int** )]
          [Unary, operator=&]
            [Constant, type=Identifier, value='y']
      [Return]
