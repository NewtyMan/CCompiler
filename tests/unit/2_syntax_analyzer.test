:testcase:
:name: Switch statement
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    switch (argc) {
        case 0:
        case 1:
            argc += 1;
            break;
        case 2:
            argc -= 1;
            break;
        default:
            break;
    }

    return 0;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
  [FuncBody]
    [CompoundStmt]
      [Switch]
        [Expr]
          [Constant, type=Identifier, value='argc']
        [Cases]
          [CompoundStmt]
            [Case]
              [Expression]
                [Constant, type=NumberOct, value='0']
              [Statement]
                [Case]
                  [Expression]
                    [Constant, type=NumberDec, value='1']
                  [Statement]
                    [Binary, operator='+=']
                      [Constant, type=Identifier, value='argc']
                      [Constant, type=NumberDec, value='1']
            [Break]
            [Case]
              [Expression]
                [Constant, type=NumberDec, value='2']
              [Statement]
                [Binary, operator='-=']
                  [Constant, type=Identifier, value='argc']
                  [Constant, type=NumberDec, value='1']
            [Break]
            [Default]
              [Break]
      [Return]
        [Constant, type=NumberOct, value='0']
:output:
:testcase:

:testcase:
:name: If-else statement
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    if (argc == 0) {
        return 0;
    } else if (argc == 1) {
        return 1;
    } else {
        return 2;
    }
    return 0;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
  [FuncBody]
    [CompoundStmt]
      [IfElse]
        [Condition]
          [Binary, operator='==']
            [Constant, type=Identifier, value='argc']
            [Constant, type=NumberOct, value='0']
        [IfStmt]
          [CompoundStmt]
            [Return]
              [Constant, type=NumberOct, value='0']
        [ElseStmt]
          [IfElse]
            [Condition]
              [Binary, operator='==']
                [Constant, type=Identifier, value='argc']
                [Constant, type=NumberDec, value='1']
            [IfStmt]
              [CompoundStmt]
                [Return]
                  [Constant, type=NumberDec, value='1']
            [ElseStmt]
              [CompoundStmt]
                [Return]
                  [Constant, type=NumberDec, value='2']
      [Return]
        [Constant, type=NumberOct, value='0']
:output:
:testcase:

:testcase:
:name: While statement
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    int x = 0;
    while (x < argc) {
        x++;
    }
    return x;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
