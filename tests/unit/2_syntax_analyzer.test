      [Declarations]
        [Declarator, name=x, type=( int )]
          [Array, size=5]
      [Declarations]
        [Declarator, name=y, type=( int )]
          [Array, size=5]
            [Array, size=10]
      [Declarations]
        [Declarator, name=result, type=( int )]
          [Binary, operator='+']
            [ArrayAccess]
