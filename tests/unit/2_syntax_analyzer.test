:output:
:testcase:

:testcase:
:name: Array declarations
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    int x[5];
    int y[5][10];

    int result = x[0] + y[1][2];
    return result;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
