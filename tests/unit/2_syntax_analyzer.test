:testcase:
:name: For statement
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    int i, x = 0;
    for (i = 0; i < argc; i++) {
        x += i;
    }
    return x;
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
  [FuncBody]
    [CompoundStmt]
      [Declarations]
        [Declarator, name=i, type=( int )]
        [Declarator, name=x, type=( int )]
          [Constant, type=NumberOct, value='0']
      [ForStmt]
        [LowExpr]
          [Binary, operator='=']
            [Constant, type=Identifier, value='i']
            [Constant, type=NumberOct, value='0']
        [HighExpr]
          [Binary, operator='<']
            [Constant, type=Identifier, value='i']
            [Constant, type=Identifier, value='argc']
        [StepExpr]
          [Postfix, operator=++]
            [Constant, type=Identifier, value='i']
        [Body]
          [CompoundStmt]
            [Binary, operator='+=']
              [Constant, type=Identifier, value='x']
              [Constant, type=Identifier, value='i']
      [Return]
        [Constant, type=Identifier, value='x']
:output:
:testcase:

:testcase:
:name: Continue statement
:flags: --syntax --syntax-print
:input:
int main(int argc, char **argv) {
    int i;
    for (i = 0; i < argc; i++) {
        if (i % 2 == 0) {
            continue;
        }
    }
}
:input:
:output:
[Function, name=main, type=( int )]
  [Parameters]
    [Parameter, name=argc, type=( int )]
    [Parameter, name=argv, type=( char** )]
  [FuncBody]
    [CompoundStmt]
      [Declarations]
        [Declarator, name=i, type=( int )]
      [ForStmt]
        [LowExpr]
          [Binary, operator='=']
            [Constant, type=Identifier, value='i']
            [Constant, type=NumberOct, value='0']
        [HighExpr]
          [Binary, operator='<']
            [Constant, type=Identifier, value='i']
            [Constant, type=Identifier, value='argc']
        [StepExpr]
          [Postfix, operator=++]
            [Constant, type=Identifier, value='i']
        [Body]
          [CompoundStmt]
            [IfElse]
              [Condition]
                [Binary, operator='==']
                  [Binary, operator='%']
                    [Constant, type=Identifier, value='i']
                    [Constant, type=NumberDec, value='2']
                  [Constant, type=NumberOct, value='0']
