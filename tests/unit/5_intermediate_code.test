:testcase:

:testcase:
:name: Do-while statement
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    int x = 0;
    do {
        x++;
    } while (x < 5);

    return x;
}
:input:
:output:
function main
write x, 0 {size=4}
L0:
t0 = read x {size=4}
t1 = t0 + 1
write x, t1 {size=4}
L1:
t0 = read x {size=4}
t1 = t0 < 5
if t1 == 0 goto L2
goto L0
L2:
t0 = read x {size=4}
return t0
:output:
:testcase:

:testcase:
:name: For statement
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    int i;
    for (i = 0; i < argc; i++) {
        i += i;
    }
    return 0;
}
:input:
:output:
function main
write i, 0 {size=4}
L0:
t0 = read argc {size=4}
t1 = read i {size=4}
t2 = t1 < t0
if t2 == 0 goto L2
t0 = read i {size=4}
t1 = read i {size=4}
t2 = t1 + t0
write i, t2 {size=4}
L1:
t0 = read i {size=4}
t1 = t0 + 1
write i, t1 {size=4}
goto L0
L2:
return 0
:output:
:testcase:

:testcase:
:name: Function call
:flags: --intermediate --intermediate-print
:input:
int sum(int a, int *b) {
    return a + *b;
}

int main(int argc, char **argv) {
    int x = 5;
    int y = sum(x, &x);
    return y;
}
:input:
:output:
function sum
t0 = read b {size=4}
t1 = read t0 {size=4}
t0 = read a {size=4}
t2 = t0 + t1
return t2
function main
write x, 5 {size=4}
t0 = read x {size=4}
parameter sum, a, t0
parameter sum, b, x
t0 = call sum {params=20}
write y, t0 {size=4}
t0 = read y {size=4}
return t0
:output:
:testcase:

:testcase:
:name: If-else statement
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    if (argc < 5) {
        return 0;
    } else {
        return 1;
    }
    return 0;
}
:input:
:output:
function main
t0 = read argc {size=4}
t1 = t0 < 5
if t1 == 0 goto L0
return 0
goto L1
L0:
return 1
L1:
return 0
:output:
:testcase: