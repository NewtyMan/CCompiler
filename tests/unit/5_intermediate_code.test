:testcase:
:name: Binary operations
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    int x = 0;
    x = x + 1;
    x = x / 2;
    x = x % 2;
    x += 1;
    return x;
}
:input:
:output:
function main
write x, 0 {size=4}
t0 = read x {size=4}
t1 = t0 + 1
write x, t1 {size=4}
t0 = read x {size=4}
t1 = t0 / 2
write x, t1 {size=4}
t0 = read x {size=4}
t1 = t0 % 2
write x, t1 {size=4}
t0 = read x {size=4}
t1 = t0 + 1
write x, t1 {size=4}
t0 = read x {size=4}
return t0
:output:
:testcase:

:testcase:
:name: Break statement
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    while (1) {
        break;
    }
    return 0;
}
:input:
:output:
function main
L0:
if 1 == 0 goto L1
goto L1
goto L0
L1:
return 0
:output:
:testcase:

:testcase:
:name: Constants
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    char a = 'a';
    char zero = '\0';
    int b = 10;
    int c = 0xFF;
    int d = 0755;
    int e = b;

    return 0;
}
:input:
:output:
function main
write a, 97 {size=1}
write zero, 0 {size=1}
write b, 10 {size=4}
write c, 255 {size=4}
write d, 493 {size=4}
t0 = read b {size=4}
write e, t0 {size=4}
return 0
:output:
:testcase:

:testcase:
:name: Declarators
