:testcase:
:name: Array access with identifiers
:flags: --intermediate --intermediate-print
:input:
int main(int argc, char **argv) {
    int x[5];
    int y = 1;

    return x[y];
}
:input:
:output:
function main
write y, 1 {size=4}
t0 = read y {size=4}
t1 = t0 * 4
t0 = x + t1
t1 = read t0 {size=4}
return t1
:output:
:testcase:

